APP_NAME="Inte-School"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8100

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database — PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=postgresql
DB_PORT=5432
DB_DATABASE=inteschool
DB_USERNAME=inteschool
DB_PASSWORD=secret

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sessions — Redis backed
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=lax

# Cache — Redis
CACHE_STORE=redis
CACHE_PREFIX=inteschool

# Queue — Redis / Horizon
QUEUE_CONNECTION=redis

# Broadcasting — Reverb
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8103
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Filesystem
FILESYSTEM_DISK=local

# GCS — media & backup (production only)
GCS_PROJECT_ID=
GCS_KEY_FILE=
GCS_BUCKET=
GCS_BUCKET_REGION=europe-west2

# Mail — Resend primary
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@inte.school"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# Mail — fallback provider
MAIL_FALLBACK_MAILER=mailgun
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# VAPID — Web Push (generate with: php artisan vapid:generate)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# Ollama — embeddings & RAG
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_GENERATE_MODEL=mistral

# SMS — fallback notifications
SMS_PROVIDER=
SMS_API_KEY=
SMS_FROM=

# SSO — disabled until Phase 2 integration
SSO_ENABLED=false
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=

# Mailpit (dev only)
MAIL_HOST=mailpit
MAIL_PORT=1025

VITE_APP_NAME="${APP_NAME}"
