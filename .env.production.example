APP_NAME="Inte-School"
APP_ENV=production
APP_KEY=                          # generated by install.sh — do not set manually
APP_DEBUG=false
APP_URL=https://school.inte.team

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_GB

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Database — PostgreSQL (pgvector/pgvector:pg16)
DB_CONNECTION=pgsql
DB_HOST=postgresql
DB_PORT=5432
DB_DATABASE=inteschool
DB_USERNAME=inteschool
DB_PASSWORD=                      # generated by install.sh

# Redis (password-protected in production)
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=                   # generated by install.sh
REDIS_PORT=6379

# Sessions
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.inte.team
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# Cache
CACHE_STORE=redis
CACHE_PREFIX=inteschool

# Queue — Horizon
QUEUE_CONNECTION=redis

# Broadcasting — Reverb (Caddy terminates TLS, Reverb runs HTTP internally)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=                    # generated by install.sh
REVERB_APP_KEY=                   # generated by install.sh
REVERB_APP_SECRET=                # generated by install.sh
REVERB_HOST=school.inte.team
REVERB_PORT=443
REVERB_SCHEME=https

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Filesystem
FILESYSTEM_DISK=local

# GCS — media & backup (fill in after provisioning bucket)
GCS_PROJECT_ID=
GCS_KEY_FILE=
GCS_BUCKET=
GCS_BUCKET_REGION=europe-west2

# Mail — Resend primary
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="noreply@inte.school"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# Mail — Mailgun fallback
MAIL_FALLBACK_MAILER=mailgun
MAILGUN_DOMAIN=
MAILGUN_SECRET=

# VAPID — Web Push (generated by install.sh via: php artisan vapid:generate)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VITE_VAPID_PUBLIC_KEY="${VAPID_PUBLIC_KEY}"

# Ollama — embeddings & RAG (point to GPU host or local Ollama sidecar)
OLLAMA_HOST=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_GENERATE_MODEL=mistral

# SMS — fallback notifications
SMS_PROVIDER=
SMS_API_KEY=
SMS_FROM=

# SSO — disabled until Phase 2
SSO_ENABLED=false
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=

VITE_APP_NAME="${APP_NAME}"
